# Auto detect text files and normalize line endings to LF
* text=auto

# Source files
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cxx text eol=lf

# Script files
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf

# Config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Makefile text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.o binary
*.a binary
*.so binary
*.exe binary
*.dll binary
*.lib binary
